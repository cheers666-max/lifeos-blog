{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "hugo",
  "frontMatter.preview.host": "http://localhost:1313",
  "frontMatter.framework.startCommand": "hugo server -D",
  "frontMatter.content.publicFolder": "static",
  "frontMatter.content.pageFolders": [
    { "title": "博客文章", "path": "[[workspace]]/content/posts" }
  ],
  "frontMatter.content.defaultFileType": "md",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "post",
      "pageBundle": true,
      "previewPath": "posts",
      "fields": [
        { "title": "标题", "name": "title", "type": "string" },
        { "title": "日期", "name": "date", "type": "datetime", "default": "{{now}}", "isPublishDate": true },
        { "title": "描述(SEO)", "name": "description", "type": "string" },
        { "title": "摘要", "name": "summary", "type": "string" },
        { "title": "标签", "name": "tags", "type": "tags" },
        { "title": "分类", "name": "categories", "type": "categories" },
        { "title": "系列", "name": "series", "type": "list" },
        { "title": "显示目录 ShowToc", "name": "ShowToc", "type": "boolean", "default": true },
        { "title": "目录默认展开 TocOpen", "name": "TocOpen", "type": "boolean", "default": false },
        { "title": "启用数学公式 math", "name": "math", "type": "boolean", "default": true },
        {
          "title": "封面 cover", "name": "cover", "type": "fields",
          "fields": [
            { "title": "图片", "name": "image", "type": "image" },
            { "title": "alt 描述", "name": "alt", "type": "string" },
            { "title": "图注", "name": "caption", "type": "string" }
          ]
        },
        { "title": "正文", "name": "content", "type": "content", "hidden": true }
      ]
    }
  ]
}
